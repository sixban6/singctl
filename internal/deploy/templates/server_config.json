{
  "dns": {
    "servers": [
      {
        "tag": "google",
        "type": "tls",
        "server": "8.8.8.8"
      },
      {
        "tag": "cloudflare",
        "type": "tls",
        "server": "1.1.1.1"
      }
    ],
    "rules": [
      {
        "query_type": "HTTPS",
        "action": "reject"
      },
      {
        "query_type": [
          "A",
          "AAAA"
        ],
        "server": "cloudflare"
      }
    ],
    "final": "cloudflare",
    "strategy": "ipv4_only"
  },
  "inbounds": [
    {
      "type": "vless",
      "tag": "vless-in",
      "listen": "::",
      "listen_port": 8443,
      "users": [
        {
          "name": "user1",
          "uuid": "{{.HyUUID}}",
          "flow": "xtls-rprx-vision"
        }
      ],
      "tls": {
        "enabled": true,
        "server_name": "www.microsoft.com",
        "reality": {
          "enabled": true,
          "handshake": {
            "server": "www.microsoft.com",
            "server_port": 443
          },
          "private_key": "{{.RealityPrivateKey}}",
          "short_id": [
            "{{.RealityShortID}}"
          ]
        }
      }
    },
    {
      "tag": "HYSTERIA2",
      "type": "hysteria2",
      "listen": "::",
      "listen_port": 52021,
      "users": [
        {
          "password": "{{.HyUUID}}"
        }
      ],
      "tls": {
        "enabled": true,
        "alpn": [
          "h3"
        ],
        "certificate_path": "{{.CertPath}}",
        "key_path": "{{.KeyPath}}"
      }
    }
  ],
  "outbounds": [
    {
      "tag": "DirectConn",
      "type": "direct"
    },
    {
      "type": "socks",
      "tag": "WARP",
      "server": "127.0.0.1",
      "server_port": 40000
    }
  ],
  "route": {
    "auto_detect_interface": true,
    "default_domain_resolver": {
      "server": "cloudflare"
    },
    "final": "DirectConn",
    "rule_set": [
      {
        "tag": "rule-youtube",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/sing/geo/geosite/youtube.srs",
        "download_detour": "DirectConn"
      },
      {
        "tag": "rule-google-domain",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/sing/geo/geosite/google.srs",
        "download_detour": "DirectConn"
      },
      {
        "tag": "rule-google-ip",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/sing/geo/geoip/google.srs",
        "download_detour": "DirectConn"
      },
      {
        "tag": "rule-openai",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/sing/geo/geosite/openai.srs",
        "download_detour": "DirectConn"
      },
      {
        "tag": "rule-anthropic",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/sing/geo/geosite/anthropic.srs",
        "download_detour": "DirectConn"
      },
      {
        "tag": "rule-github",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/sing/geo/geosite/github.srs",
        "download_detour": "DirectConn"
      }
    ],
    "rules": [
      {
        "action": "sniff",
        "timeout": "1s"
      },
      {
        "action": "hijack-dns",
        "mode": "or",
        "rules": [
          {
            "port": 53
          },
          {
            "protocol": "dns"
          }
        ],
        "type": "logical"
      },
      {
        "ip_is_private": true,
        "outbound": "DirectConn"
      },
      {
        "rule_set": [
          "rule-youtube"
        ],
        "outbound": "DirectConn"
      },
      {
        "rule_set": [
          "rule-google-domain",
          "rule-google-ip",
          "rule-openai",
          "rule-anthropic",
          "rule-github"
        ],
        "outbound": "WARP"
      }
    ]
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "path": "/etc/sing-box/cache.db"
    }
  },
  "log": {
    "disabled": false,
    "level": "info",
    "timestamp": true
  }
}